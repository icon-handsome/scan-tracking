{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure (Ninja Debug)",
      "type": "shell",
      "command": "${workspaceFolder}/tools/scan_tracking_dev.cmd",
      "args": [
        "configure-debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [],
      "group": "build"
    },
    {
      "label": "Build (Ninja Debug)",
      "type": "shell",
      "command": "${workspaceFolder}/tools/scan_tracking_dev.cmd",
      "args": [
        "build-debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "Configure (Ninja Debug)"
      ],
      "dependsOrder": "sequence",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Run scan-tracking",
      "type": "shell",
      "command": "${workspaceFolder}/tools/scan_tracking_dev.cmd",
      "args": [
        "run-debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PATH": "${workspaceFolder}/build/win-msvc2019-qtcore-ninja-debug/app;${workspaceFolder}/build/win-msvc2019-qtcore-ninja-debug/app/mech_eye_api;${workspaceFolder}/build/win-msvc2019-qtcore-ninja-debug/app/ThirdParty;${workspaceFolder}/build/win-msvc2019-qtcore-ninja-debug/app/hik_mvs_runtime;${workspaceFolder}/build/win-msvc2019-qtcore-ninja-debug/app/OpenNI2;${workspaceFolder}/build/win-msvc2019-qtcore-ninja-debug/app/OpenNI2/Drivers;C:/Qt/5.15.2/msvc2019_64/bin;C:/Program Files/PCL 1.12.0/bin;C:/Program Files/PCL 1.12.0/3rdParty/VTK/bin;C:/Program Files/OpenNI2/Redist;${workspaceFolder}/third_party/LB/opencv-3.4.3-vc14_vc15/opencv/build/x64/vc15/bin;${workspaceFolder}/third_party/Mech-Eye SDK-2.5.4/API/dll;${workspaceFolder}/third_party/Mech-Eye SDK-2.5.4/API/dll_debug;${env:PATH}"
        }
      },
      "dependsOn": [
        "Build (Ninja Debug)"
      ],
      "dependsOrder": "sequence",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true,
        "close": false
      },
      "problemMatcher": []
    },
    {
      "label": "Rebuild (Ninja Debug)",
      "type": "shell",
      "command": "${workspaceFolder}/tools/scan_tracking_dev.cmd",
      "args": [
        "build-debug"
      ],
      "dependsOn": [
        "Clean Build Directory",
        "Configure (Ninja Debug)"
      ],
      "dependsOrder": "sequence",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": [
        "$msCompile"
      ],
      "group": "build"
    },
    {
      "label": "Clean Build Directory",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-Command",
        "$target = Resolve-Path -LiteralPath '${workspaceFolder}/build/win-msvc2019-qtcore-ninja-debug' -ErrorAction SilentlyContinue; if ($target) { Remove-Item -LiteralPath $target.Path -Recurse -Force }"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
